// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum ServiceType {
  SUNDAY_MAIN
  SUNDAY_SCHOOL
  WEDNESDAY
  FRIDAY
  SPECIAL
}

enum BulletinType {
  BULLETIN
  PPT
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model Admin {
  id             Int      @id @default(autoincrement())
  email          String   @unique
  hashedPassword String
  name           String
  role           String   @default("ADMIN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("admins")
}

model Sermon {
  id          Int         @id @default(autoincrement())
  title       String
  scripture   String
  sermonDate  DateTime
  serviceType ServiceType
  youtubeUrl  String?
  youtubeId   String?
  blogUrl     String?
  summary     String?     @db.Text
  series      String?
  tags        String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  columns     Column[]

  @@index([sermonDate])
  @@index([serviceType])
  @@index([youtubeId])
  @@map("sermons")
}

model Column {
  id            Int      @id @default(autoincrement())
  title         String
  content       String   @db.Text
  scripture     String?
  sermonId      Int?
  sermon        Sermon?  @relation(fields: [sermonId], references: [id])
  coverImageUrl String?
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([createdAt])
  @@index([sermonId])
  @@index([viewCount])
  @@map("columns")
}

model PraiseConti {
  id            Int      @id @default(autoincrement())
  title         String
  serviceDate   DateTime
  fileName      String
  fileUrl       String
  fileSize      Int
  downloadCount Int      @default(0)
  musicalKey    String?  // 코드: A, B, C, D, E, F, G 등
  theme         String?  // 메세지/주제: 은혜, 성령, 부흥, 왕 등
  season        String?  // 절기: 성탄, 부활, 추수감사, 사순절 등
  createdAt     DateTime @default(now())

  @@index([musicalKey])
  @@index([theme])
  @@index([season])
  @@map("praise_contis")
}

model Bulletin {
  id           Int          @id @default(autoincrement())
  title        String
  serviceDate  DateTime
  bulletinType BulletinType
  createdAt    DateTime     @default(now())

  files        BulletinFile[]

  @@map("bulletins")
}

model BulletinFile {
  id            Int      @id @default(autoincrement())
  fileName      String
  fileUrl       String
  fileSize      Int
  downloadCount Int      @default(0)
  bulletinId    Int
  bulletin      Bulletin @relation(fields: [bulletinId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@map("bulletin_files")
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  title     String?
  category  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("gallery_images")
}

model SiteSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model PageView {
  id        Int      @id @default(autoincrement())
  path      String
  referrer  String?
  createdAt DateTime @default(now())

  @@map("page_views")
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String?   @db.Text
  startDate   DateTime
  endDate     DateTime?
  isAllDay    Boolean   @default(true)
  eventType   String    @default("general") // general, special, worship, meeting
  createdAt   DateTime  @default(now())

  @@index([startDate])
  @@map("events")
}

model PrayerRequest {
  id          Int      @id @default(autoincrement())
  name        String   @default("익명")
  content     String   @db.Text
  isAnonymous Boolean  @default(false)
  isAnswered  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@map("prayer_requests")
}
